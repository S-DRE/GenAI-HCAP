# Groq API — free tier at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Model to use — defaults to llama-3.3-70b-versatile. Switch to llama-3.1-8b-instant
# if the 70B daily token limit (100k TPD on free tier) is exhausted.
GROQ_MODEL=llama-3.3-70b-versatile

# LangSmith tracing — free tier at https://smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=genai-hcap
LANGCHAIN_TRACING_V2=true

# ChromaDB local persistence
CHROMA_PERSIST_DIR=./data/chroma

# Voice model configuration
# Whisper model size: tiny | base | small | medium | large (larger = more accurate, slower)
WHISPER_MODEL_SIZE=base
# Coqui TTS model (downloaded on first use)
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
